   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "countries=[\"USA\",\"Europe\",\"Ethiopia(Local)\",\"Asia\"]\n",
    "\n",
    "shares=[45,30,15,10]\n",
    "\n",
    "plt.pie(shares,labels=countries,autopct='%1.1f%%',startangle=90)\n",
    "\n",
    "plt.title(\"My Freelance Income Service By Country Name\")\n",
    "\n",
    "plt.show()\n",
    "\n"
   ]
